#!/usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail

# ==============================
# CHERCHE - v2.0
# ==============================

usage() {
  cat <<'EOF'

-----------------------------------------------
CHERCHE — recherche simple de fichiers et dossiers
Version 2.0 — avril 2026
-----------------------------------------------

Usage:
  cherche <fichier|dossier> [options] --dans <chemin> [action]

Options :
  --dans <chemin>        (obligatoire)
  --nom <nom_exact>
  --contient <texte>
  --extension <ext>
  --vide
  --non-recursif

Actions :
  --afficher             (par défaut)
  --compter
  --supprimer

Auteur :
  viftbn

EOF
}

die() {
  printf 'Erreur: %s\n' "$1" >&2
  exit 1
}

# ------------------------------
# Variables par défaut
# ------------------------------
TARGET_TYPE=""
SEARCH_PATH=""
NAME_FILTER=""
CONTAINS_FILTER=""
EXT_FILTER=""
ACTION="afficher"
RESULT_COUNT=0
MATCH_COUNT=0
NON_RECURSIF=0
EMPTY_FILTER=0
RESULTS_TO_DELETE=()

# ------------------------------
# Validation minimale
# ------------------------------
[[ $# -ge 1 ]] || {
  usage
  exit 0
}

TARGET_TYPE="$1"
shift

case "$TARGET_TYPE" in
  fichier|dossier)
    ;;
  *)
    die "le premier argument doit être 'fichier' ou 'dossier'"
    ;;
esac

# ------------------------------
# Parseur d'arguments V1
# ------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dans)
      [[ $# -ge 2 ]] || die "--dans attend un chemin"
      SEARCH_PATH="$2"
      shift 2
      ;;

    --nom)
      [[ $# -ge 2 ]] || die "--nom attend une valeur"
      NAME_FILTER="$2"
      shift 2
      ;;

    --contient)
      [[ $# -ge 2 ]] || die "--contient attend une valeur"
      CONTAINS_FILTER="$2"
      shift 2
      ;;

    --extension)
      [[ $# -ge 2 ]] || die "--extension attend une valeur"
      EXT_FILTER="$2"
      shift 2
      ;;
    --non-recursif)
      NON_RECURSIF=1
      shift
      ;;

    --vide)
      EMPTY_FILTER=1
      shift
      ;;

    --afficher)
      ACTION="afficher"
      shift
      ;;

    --compter)
      ACTION="compter"
      shift
      ;;
    --supprimer)
      ACTION="supprimer"
      shift
      ;;

    *)
      die "option inconnue : $1"
      ;;
  esac
done

[[ -n "$SEARCH_PATH" ]] || die "--dans est obligatoire"
[[ -d "$SEARCH_PATH" ]] || die "le chemin '$SEARCH_PATH' n'existe pas ou n'est pas un dossier"
[[ -n "$EXT_FILTER" && "$TARGET_TYPE" == "dossier" ]] && \
  die "--extension est utilisable uniquement avec 'fichier'"


# ------------------------------
# Moteur de parcours récursif
# ------------------------------

matches_type() {
  local path="$1"

  case "$TARGET_TYPE" in
    fichier)
      [[ -f "$path" ]]
      ;;
    dossier)
      [[ -d "$path" ]]
      ;;
    *)
      return 1
      ;;
  esac
}

matches_name() {
  local path="$1"
  local base_name=""

  [[ -z "$NAME_FILTER" ]] && return 0

  base_name="$(basename "$path")"

  [[ "$base_name" == "$NAME_FILTER" ]]
}

matches_extension() {
  local path="$1"
  local base_name=""

  [[ -z "$EXT_FILTER" ]] && return 0

  base_name="$(basename "$path")"

  [[ "$base_name" == *."$EXT_FILTER" ]]
}

matches_contains() {
  local path="$1"
  local base_name=""

  [[ -z "$CONTAINS_FILTER" ]] && return 0

  base_name="$(basename "$path")"

  [[ "$base_name" == *"$CONTAINS_FILTER"* ]]
}

matches_empty() {
 local path="$1"
 local entry=""

 [[ "$EMPTY_FILTER" -eq 0 ]] && return 0

 case "$TARGET_TYPE" in
  fichier)
    [[ -f "$path" && ! -s "$path" ]]
    ;;

  dossier)
    [[ -d "$path" ]] || return 1

    for entry in "$path"/* "$path"/.[!.]* "$path"/..?*; do
    [[ -e "$entry" ]] && return 1
    done

    return 0
    ;;

  *)
    return 1
    ;;
 esac
}

# fonction dédiée aux filtres

matches_filters() {
  local path="$1"

  matches_type "$path" &&
  matches_name "$path" &&
  matches_extension "$path" &&
  matches_contains "$path" &&
  matches_empty "$path"
}

# filtrage des données avant suppression

filter_delete_targets() {
 local path=""
 local other=""
 local keep=1
 local filtered_results=()

 for path in "${RESULTS_TO_DELETE[@]}"; do
  keep=1

  for other in "${RESULTS_TO_DELETE[@]}"; do
   [[ "$path" == "$other" ]] && continue

   case "$path" in
    "$other"/*)
     keep=0
     break
     ;;
   esac
  done

  [[ "$keep" -eq 1 ]] && filtered_results+=("$path")
 done

 RESULTS_TO_DELETE=("${filtered_results[@]}")
}

# ----------------------------------------
# walk = le moteur de parcours récursif
# ---------------------------------------

walk() {
 local current_path="$1"
 local root_path="$2"
 local current_depth="$3"
 local entry=""

 if [[ "$current_path" != "$root_path" ]] && matches_filters "$current_path"; then
 ((MATCH_COUNT+=1))

 case "$ACTION" in
   afficher)
     printf '%s\n' "$current_path"
     ;;
   compter)
     ((RESULT_COUNT+=1))
     ;;
   supprimer)
     RESULTS_TO_DELETE+=("$current_path")
     ;;
     *)
     die "action inconnue : $ACTION"
     ;;
 esac
 fi

 [[ -d "$current_path" ]] || return 0

 if [[ "$NON_RECURSIF" -eq 1 && "$current_depth" -ge 1 ]]; then
 return 0
 fi

 for entry in "$current_path"/*; do
 [[ -e "$entry" ]] || continue
 walk "$entry" "$root_path" $((current_depth + 1))
 done
}

walk "$SEARCH_PATH" "$SEARCH_PATH" 0

#affichage final du total

if [[ "$ACTION" == "compter" ]]; then
 printf '%s\n' "$RESULT_COUNT"

elif [[ "$ACTION" == "supprimer" ]]; then
 if [[ "${#RESULTS_TO_DELETE[@]}" -eq 0 ]]; then
  printf 'Aucun résultat trouvé\n'
  exit 0
 fi

 filter_delete_targets

 printf 'Éléments à supprimer :\n'
 for path in "${RESULTS_TO_DELETE[@]}"; do
  printf '%s\n' "$path"
 done

 printf 'Attention : les dossiers seront supprimés récursivement avec leur contenu.\n'
 printf 'Continuer ? (O/n): '

 read -r confirmation

 case "$confirmation" in
  ""|O|o)
   ;;
  N|n)
   printf 'Suppression annulée\n'
   exit 0
   ;;
  *)
   printf 'Réponse invalide. Suppression annulée\n'
   exit 1
   ;;
 esac

 for path in "${RESULTS_TO_DELETE[@]}"; do
  rm -rf -- "$path"
  printf 'Supprimé : %s\n' "$path"
 done

elif [[ "$MATCH_COUNT" -eq 0 ]]; then
 printf 'Aucun résultat trouvé\n'
fi
